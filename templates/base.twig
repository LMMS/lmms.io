{% import 'navbar.twig' as nav %}
{% import 'macros.twig' as macros %}
{% set uri = app.request.pathinfo %}
<!DOCTYPE HTML>
<html>
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{% block title %}LMMS | {{ nav.get_active_title(uri)|trim }}{% endblock %}</title>

	<meta name="description" content="LMMS is a free, open source, multiplatform digital audio workstation.">
	<link rel="icon" type="image/png" href="/img/logo_sm.png">
	{% block stylesheets %}
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css" integrity="sha256-l85OmPOjvil/SOvVt3HnSSjzF1TUMyT9eV0c2BzEGzU=" crossorigin="anonymous" />
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.4.1/css/bootstrap.min.css" integrity="sha256-bZLfwXAP04zRMK2BjiO8iu9pf4FbLqX6zitd+tIvLhE=" crossorigin="anonymous" />
	<link href="//fonts.googleapis.com/css?family=Titillium+Web:400,600|Orbitron:500|Noto+Sans:400,700&amp;subset=cyrillic,cyrillic-ext,devanagari,greek,greek-ext,latin-ext,vietnamese" rel="stylesheet">
	<link href="/css/style.css" rel="stylesheet">
	<script defer src="https://use.fontawesome.com/releases/v6.7.2/js/all.js"></script>
	{% endblock %}
</head>

<body role="document">
	<nav class="navbar navbar-custom navbar-fixed-top" role="navigation">
		<div class="container">
			<div class="navbar-header">
				<button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
					<span class="sr-only">Toggle navigation</span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
				</button>
				<a class="navbar-brand" href="/"><img alt="LMMS Logo" class="logo-sm pull-left" height="22px" width="22px" src="/img/brand-icon.png"></img>LMMS</a>
			</div>

			<div class="navbar-collapse collapse">
				<ul class="nav navbar-nav">
					{{ nav.build_navbar(uri) }}
				</ul>
			</div>
		</div>
	</nav>

	{% block header %}{% endblock %}
	<div class="theme-showcase main-div" role="main" dir="auto">
		{% block content %}{% endblock %}
	</div>

	<footer id="footer">
		<div class="container">
			<div class="row">
				<div class="column-md-6 pull-right">
					<a class="social" href="https://github.com/LMMS">{{ macros.square_stack('fa-github', 'fa-4x', true, '') }}</a>
					<a class="social" href="https://facebook.com/makefreemusic">{{ macros.square_stack('fa-facebook', 'fa-4x', true, '') }}</a>
					<a class="social" href="https://twitter.com/lmmsio">{{ macros.square_stack('fa-x-twitter', 'fa-4x', true, '') }}</a>
					<a class="social" href="/chat">{{ macros.square_stack('fa-discord', 'fa-4x', true, '') }}</a>
					<a class="social" href="https://lmms.bandcamp.com">{{ macros.square_stack('fa-bandcamp', 'fa-4x', true, '') }}</a>
					<a class="social" href="https://www.youtube.com/user/LMMSOfficial">{{ macros.square_stack('fa-youtube', 'fa-4x', true, '') }}</a>
				</div>

				<div id="redux" class="column-md-6">
					<p>{% trans %}Powered by{% endtrans %} </p>
					<p><a href="https://www.digitalocean.com/?refcode=c77894a32e56&utm_campaign=Referral_Invite&utm_medium=Referral_Program&utm_source=badge"><img src="/img/digital_ocean.png"></a></p>
				</div>
			</div>
		</div>
	</footer>

	{% block javascripts %}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.4.1/jquery.min.js" integrity="sha256-CSXorXvZcTkaix6Yvo6HppcZGetbYMGWSFlBw8HfCJo=" crossorigin="anonymous"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.4.1/js/bootstrap.min.js" integrity="sha256-nuL8/2cJ5NDSSwnKD8VqreErSWHtnEP9E7AySL+1ev4=" crossorigin="anonymous"></script>
	<script src="/js/smartNavbar.js"></script>
	{% endblock %}
	{% block foot %}{% endblock %}
	<script type="text/javascript" src="/js/analytics.js"></script>
</body>
</html>
